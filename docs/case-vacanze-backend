          <script>
          // Filtro date collegato alle case vacanza, stile e UX come prenotazione.html
          document.addEventListener('DOMContentLoaded', function() {
            var showBtn = document.getElementById('show-date-filter');
            var form = document.getElementById('date-filter-form');
            var checkinInput = document.getElementById('checkin');
            var checkoutInput = document.getElementById('checkout');
            if (showBtn && form) {
              showBtn.addEventListener('click', function() {
                form.style.display = (form.style.display === 'none' || form.style.display === '') ? 'block' : 'none';
              });
            }

            // Flatpickr per UX calendario come prenotazione.html
            function enableOnlySaturday(date) { return (date.getDay() === 6); }
            let checkInSelected = null;
            if (window.flatpickr) {
              flatpickr(checkinInput, {
                dateFormat: "Y-m-d",
                locale: "it",
                disable: [function(date) { return !enableOnlySaturday(date); }],
                minDate: "today",
                onChange: function(selectedDates, dateStr) {
                  checkInSelected = selectedDates && selectedDates[0] ? selectedDates[0] : null;
                  // Aggiorna il calendario di checkOut
                  if (checkoutInput._flatpickr) {
                    const minDate = checkInSelected ? new Date(checkInSelected.getTime() + 24*60*60*1000) : "today";
                    checkoutInput._flatpickr.set('minDate', minDate);
                    checkoutInput._flatpickr.redraw();
                    checkoutInput.value = '';
                    // Forza la vista del calendario sul primo sabato valido dopo il check-in
                    if (checkInSelected) {
                      let nextSaturday = new Date(checkInSelected.getTime() + 24*60*60*1000);
                      while (nextSaturday.getDay() !== 6) {
                        nextSaturday.setDate(nextSaturday.getDate() + 1);
                      }
                      checkoutInput._flatpickr.jumpToDate(nextSaturday);
                    }
                  }
                }
              });
              flatpickr(checkoutInput, {
                dateFormat: "Y-m-d",
                locale: "it",
                disable: [
                  function(date) {
                    if (!enableOnlySaturday(date)) return true;
                    if (checkinInput.value) {
                      const checkInDate = new Date(checkinInput.value);
                      if (date <= checkInDate) return true;
                    }
                    return false;
                  }
                ],
                minDate: "today"
              });
            }

            // Salva i dati delle case e prenotazioni per il filtro
            window._caseVacanzaData = { houses: [], bookings: {} };

            // Intercetta submit del filtro
            form && form.addEventListener('submit', function(e) {
              e.preventDefault();
              var checkin = checkinInput.value;
              var checkout = checkoutInput.value;
              if (!checkin || !checkout || checkout <= checkin) {
                alert('Inserisci date valide (check-out dopo check-in)');
                return;
              }
              var houses = window._caseVacanzaData.houses;
              var bookingsMap = window._caseVacanzaData.bookings;
              var fullyAvailable = [];
              var partiallyAvailable = [];
              houses.forEach(function(house) {
                var bookings = bookingsMap[house.id] || [];
                if (!bookings.length) {
                  fullyAvailable.push(house);
                  return;
                }
                // Trova se la casa è libera per tutto il periodo
                var isFree = true;
                for (var i=0; i<bookings.length; i++) {
                  var b = bookings[i];
                  if (!(checkout <= b.checkIn || checkin >= b.checkOut)) {
                    isFree = false;
                    break;
                  }
                }
                if (isFree) {
                  fullyAvailable.push(house);
                  return;
                }
                // Trova periodi parziali disponibili all'interno del range richiesto
                var freeRanges = [];
                var rangeStart = new Date(checkin);
                var rangeEnd = new Date(checkout);
                // Crea array di giorni occupati
                var occupied = [];
                bookings.forEach(function(b) {
                  var d1 = new Date(b.checkIn);
                  var d2 = new Date(b.checkOut);
                  for (var d = new Date(d1); d < d2; d.setDate(d.getDate() + 1)) {
                    occupied.push(d.toISOString().slice(0,10));
                  }
                });
                // Trova i periodi liberi all'interno del range richiesto
                var current = null;
                for (var d = new Date(rangeStart); d <= rangeEnd; d.setDate(d.getDate() + 1)) {
                  var ds = d.toISOString().slice(0,10);
                  if (occupied.indexOf(ds) === -1) {
                    if (!current) current = { dal: ds, al: ds };
                    else current.al = ds;
                  } else {
                    // Se il giorno occupato è il check-in di una prenotazione ed è compreso nel periodo richiesto, includilo come libero
                    var isCheckIn = bookings.some(function(b) { return b.checkIn === ds && ds >= checkin && ds <= checkout; });
                    if (isCheckIn) {
                      if (!current) current = { dal: ds, al: ds };
                      else current.al = ds;
                    } else {
                      if (current) {
                        freeRanges.push({ dal: current.dal, al: current.al });
                        current = null;
                      }
                    }
                  }
                }
                if (current) freeRanges.push(current);
                // Se almeno un periodo libero di almeno 3 giorni consecutivi, aggiungi a parziali
                var minConsecutiveDays = 3;
                var validRanges = freeRanges.filter(function(p) {
                  var start = new Date(p.dal);
                  var end = new Date(p.al);
                  // Calcola giorni inclusivi
                  var days = Math.floor((end - start) / (1000*60*60*24)) + 1;
                  return days >= minConsecutiveDays;
                });
                if (validRanges.length > 0) {
                  house._partialFree = validRanges;
                  partiallyAvailable.push(house);
                }
              });
              // Rendering
              var grid = window._caseVacanzaGrid || document.getElementById('properties-grid');
              grid.innerHTML = '';
              if (fullyAvailable.length > 0) {
                var title = document.createElement('h2');
                title.textContent = 'Case disponibili per tutto il periodo selezionato:';
                title.style = 'width:100%;text-align:center;margin:32px 0 18px 0;color:#128c7e;font-size:1.2em;';
                grid.appendChild(title);
                fullyAvailable.forEach(function(house) {
                  var card = document.createElement('div');
                  card.className = 'property-card fade-in';
                  card.innerHTML = house._cardHtml;
                  grid.appendChild(card);
                });
              }
              if (partiallyAvailable.length > 0) {
                var title2 = document.createElement('h2');
                title2.textContent = 'Case con disponibilità parziale nel periodo selezionato:';
                title2.style = 'width:100%;text-align:center;margin:32px 0 18px 0;color:#b8860b;font-size:1.1em;';
                grid.appendChild(title2);
                partiallyAvailable.forEach(function(house) {
                  var card = document.createElement('div');
                  card.className = 'property-card fade-in';
                  card.innerHTML = house._cardHtml;
                  // Evidenzia i periodi liberi parziali
                  var periodiDiv = card.querySelector('.periodi-disponibili > div');
                  if (periodiDiv && house._partialFree) {
                    periodiDiv.innerHTML = house._partialFree.map(function(p) {
                      var opts = { day: '2-digit', month: '2-digit' };
                      var dDal = new Date(p.dal);
                      var dAl = new Date(p.al);
                      if (p.dal === p.al) return `<span class='periodo-badge' style='background:#fffbe6;color:#b8860b;border:1.5px solid #ffe066;'>${dDal.toLocaleDateString('it-IT', opts)}</span>`;
                      return `<span class='periodo-badge' style='background:#fffbe6;color:#b8860b;border:1.5px solid #ffe066;'>${dDal.toLocaleDateString('it-IT', opts)} - ${dAl.toLocaleDateString('it-IT', opts)}</span>`;
                    }).join('');
                  }
                  grid.appendChild(card);
                });
              }
              if (fullyAvailable.length === 0 && partiallyAvailable.length === 0) {
                grid.innerHTML = '<div style="color:#b00;font-size:1.2em;margin:32px auto;">Nessuna casa disponibile per le date selezionate.</div>';
              }
            });

            function renderPropertiesGrid(houses) {
              if (!window._caseVacanzaGrid) {
                window._caseVacanzaGrid = document.getElementById('properties-grid');
              }
              var grid = window._caseVacanzaGrid;
              if (!grid) return;
              grid.innerHTML = '';
              if (!houses.length) {
                grid.innerHTML = '<div style="color:#b00;font-size:1.2em;margin:32px auto;">Nessuna casa disponibile per le date selezionate.</div>';
                return;
              }
              houses.forEach(function(house, idx) {
                var card = document.createElement('div');
                card.className = 'property-card fade-in';
                card.innerHTML = house._cardHtml;
                grid.appendChild(card);
              });
            }
          });
          // Flatpickr JS CDN
          </script>
