    <div id="properties-grid" class="properties-grid"></div>
    <script>
    document.addEventListener('DOMContentLoaded', async function() {
      let grid = document.getElementById('properties-grid');
      try {
        const res = await fetch('https://demo-mail-993653817397.europe-west8.run.app/api/case/public');
        const houses = await res.json();
        grid.innerHTML = '';

        // Funzione per generare tutte le date della stagione (1 giugno - 30 settembre)
        function getAllSeasonDates() {
          const startSeason = new Date(Date.UTC(new Date().getFullYear(), 5, 1)); // 1 giugno UTC
          const endSeason = new Date(Date.UTC(new Date().getFullYear(), 8, 30)); // 30 settembre UTC
          let allDates = [];
          let d = new Date(startSeason);
          while (d <= endSeason) {
            allDates.push(d.toISOString().slice(0,10));
            d.setUTCDate(d.getUTCDate() + 1);
          }
          return allDates;
        }

        // Funzione per formattare periodo
        function formatPeriodo(dal, al) {
          const opts = { day: '2-digit', month: '2-digit' };
          const dDal = new Date(dal);
          const dAl = new Date(al);
          if (dal === al) return dDal.toLocaleDateString('it-IT', opts);
          return dDal.toLocaleDateString('it-IT', opts) + ' - ' + dAl.toLocaleDateString('it-IT', opts);
        }

        // Carica tutte le prenotazioni in parallelo e mostra i CTA solo dopo
        // Salva anche le prenotazioni per il filtro
        let allBookings = {};
        await Promise.all(houses.map(async (house, idx) => {
          // Ottieni tutte le date della stagione (nuovo array per ogni casa)
          let allDates = getAllSeasonDates();

          // Fetch prenotazioni per la casa
          let bookedDates = new Set();
          let prenotazioni = [];
          try {
            const resP = await fetch(`https://demo-mail-993653817397.europe-west8.run.app/api/prenotazioni/casa/${house.id}`);
            prenotazioni = await resP.json();
            prenotazioni.forEach(p => {
              if (!p.checkIn || !p.checkOut) return;
              let d = new Date(Date.UTC(
                parseInt(p.checkIn.slice(0,4)),
                parseInt(p.checkIn.slice(5,7))-1,
                parseInt(p.checkIn.slice(8,10))
              ));
              const end = new Date(Date.UTC(
                parseInt(p.checkOut.slice(0,4)),
                parseInt(p.checkOut.slice(5,7))-1,
                parseInt(p.checkOut.slice(8,10))
              ));
              while (d < end) { // il giorno di checkOut NON è occupato
                const key = d.toISOString().slice(0,10);
                bookedDates.add(key);
                d.setUTCDate(d.getUTCDate() + 1);
              }
            });
          } catch {}
          // Calcola periodi disponibili continui
          let periodiDisponibili = [];
          let periodoInCorso = null;
          allDates.forEach((date, idx) => {
            if (!bookedDates.has(date)) {
              if (!periodoInCorso) periodoInCorso = { dal: date, al: date };
              else periodoInCorso.al = date;
            } else {
              if (periodoInCorso) {
                // Chiudi il periodo includendo anche il giorno prenotato
                periodiDisponibili.push({ dal: periodoInCorso.dal, al: date });
                periodoInCorso = null;
              }
            }
            if (idx === allDates.length-1 && periodoInCorso) {
              periodiDisponibili.push(periodoInCorso);
            }
          });

          // Filtro: escludi periodi che iniziano o finiscono il 31/05
          function is31Maggio(dateStr) {
            return dateStr.endsWith('-05-31');
          }
          periodiDisponibili = periodiDisponibili.filter(p => !is31Maggio(p.dal) && !is31Maggio(p.al));

          // Salva HTML della card per riuso nel filtro
          house._cardHtml = `
            <div class="availability-badge">${house.disponibile ? '✔️ Disponibile' : '❌ Non disponibile'}</div>
            <div class="property-image">
              <a href="${house.link_dettaglio || '#'}" class="image-link-casa" style="display:block;position:relative;overflow:hidden;">
                <img src="${house.immagine || 'img/default.webp'}" alt="${house.nome}" width="648" height="486" style="cursor:pointer;transition:transform 0.25s;display:block;width:100%;height:100%;object-fit:cover;">
                <span class="image-overlay-label">Vedi dettagli</span>
              </a>
            </div>
            <div class="property-info">
              <h3 class="property-title">${house.nome}</h3>
              <p class="property-subtitle">${house.sottotitolo || ''}</p>
              <div class="property-features">
                ${(house.caratteristiche ? house.caratteristiche.split(',').map(f => `<span class='feature-badge'>${f.trim()}</span>`).join(' ') : '')}
              </div>
              <p class="property-description">${house.descrizione || ''}</p>
              <div class="periodi-disponibili">
                <strong><span class="calendar-icon">📅</span>Periodi disponibili:</strong>
                <div>
                  ${periodiDisponibili.length > 0
                    ? periodiDisponibili.map(p => `<span class='periodo-badge'>${formatPeriodo(p.dal, p.al)}</span>`).join('')
                    : '<span style="color:#888">Nessun periodo disponibile</span>'}
                </div>
              </div>
            </div>
          `;
          // Salva le prenotazioni per il filtro
          allBookings[house.id] = prenotazioni;
        }));

        // Salva dati globali per il filtro
        window._caseVacanzaData = { houses: houses, bookings: allBookings };

        // Mostra tutte le case all’inizio
        grid.innerHTML = '';
        houses.forEach(function(house, idx) {
          var card = document.createElement('div');
          card.className = 'property-card fade-in';
          card.innerHTML = house._cardHtml;
          grid.appendChild(card);
          // Evidenzia tutti i sottotitoli
          var subtitle = card.querySelector('.property-subtitle');
          if (subtitle) {
            subtitle.classList.add('property-subtitle-evidenziata');
          }
        });

        // Solo ora mostra i CTA
        const cta = document.getElementById('cta-buttons');
        cta.style.opacity = '1';
        cta.style.pointerEvents = 'auto';
      } catch (e) {
        grid.innerHTML = '<div style="color:red">Errore nel caricamento delle case vacanza.</div>';
      }
    });
    // Evidenzia anche dopo filtro date
    window.addEventListener('DOMContentLoaded', function() {
      const grid = document.getElementById('properties-grid');
      const observer = new MutationObserver(() => {
        grid.querySelectorAll('.property-subtitle').forEach(subtitle => {
          subtitle.classList.add('property-subtitle-evidenziata');
        });
      });
      observer.observe(grid, { childList: true, subtree: true });
    });
    </script>
